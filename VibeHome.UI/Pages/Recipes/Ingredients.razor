@using VibeHome.Application.Interfaces
@using VibeHome.Domain.Entities
@using VibeHome.UI.Shared
@page "/Recipes/ingredients"
@attribute [Authorize(Roles = "recipes")]
@inject IIngredientService IngredientService

<h3>Ingredients Library</h3>

<button class="btn btn-primary mb-3" @onclick="ToggleForm">
    @(showForm ? "Hide Form" : "Add Ingredient")
</button>
<button class="btn btn-outline-secondary ms-2 mb-3" @onclick="ToggleSearch">
    @(showSearch ? "Hide Search" : "Search")
</button>

@if (showSearch)
{
    <SearchFilterComponent
        TotalCount="@allIngredients.Count"
        FilteredCount="@filteredIngredients.Count"
        ShowDateFilter="false"
        OnFiltersChanged="OnFiltersChanged" />
}

<div class="collapse @(showForm ? "show" : "")">
    <div class="card card-body mb-3">
        <EditForm Model="ingredientModel" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <div class="mb-3">
                <label class="form-label fw-semibold">Ingredient Name</label>
                <InputText class="form-control form-control-lg" @bind-Value="ingredientModel.IngredientName"
                           placeholder="e.g. Olive Oil" />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success flex-fill" disabled="@isSubmitting">
                    @(ingredientModel.IngredientId == 0 ? "Add Ingredient" : "Update")
                </button>
                @if (ingredientModel.IngredientId != 0)
                {
                    <button type="button" class="btn btn-secondary flex-fill" @onclick="ClearForm" disabled="@isSubmitting">Cancel</button>
                }
            </div>
        </EditForm>
    </div>
</div>

@if (isLoading)
{
    <div class="text-center py-4"><div class="spinner-border text-success" role="status"></div></div>
}
else
{
    <!-- Desktop Table -->
    <div class="d-none d-md-block">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th class="custom-table-header">Ingredient Name</th>
                    <th class="custom-table-header text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in filteredIngredients)
                {
                    <tr>
                        <td>@item.IngredientName</td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-info me-1" @onclick="@(() => EditIngredient(item))" disabled="@isSubmitting">Edit</button>
                            <button class="btn btn-sm btn-danger" @onclick="@(async () => await DeleteIngredient(item.IngredientId))" disabled="@isSubmitting">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Mobile Cards -->
    <div class="d-block d-md-none">
        @foreach (var item in filteredIngredients)
        {
            <div class="card mb-2 shadow-sm">
                <div class="card-body p-3">
                    <div class="fw-semibold fs-6">@item.IngredientName.ToTitleCase()</div>
                    <div class="mt-2 d-flex gap-2">
                        <button class="btn btn-info flex-fill btn-sm" @onclick="@(() => EditIngredient(item))" disabled="@isSubmitting">Edit</button>
                        <button class="btn btn-danger flex-fill btn-sm" @onclick="@(async () => await DeleteIngredient(item.IngredientId))" disabled="@isSubmitting">Delete</button>
                    </div>
                </div>
            </div>
        }
        @if (!filteredIngredients.Any())
        {
            <div class="text-center text-muted py-4">No ingredients found.</div>
        }
    </div>
}

@code {
    private List<Ingredient> allIngredients = new();
    private List<Ingredient> filteredIngredients = new();
    private Ingredient ingredientModel = new();
    private bool showForm = false;
    private bool showSearch = false;
    private bool isLoading = true;
    private bool isSubmitting = false;
    private SearchFilterComponent.SearchFilterCriteria currentFilters = new();

    protected override async Task OnInitializedAsync() => await LoadIngredients();

    private async Task LoadIngredients()
    {
        isLoading = true;
        allIngredients = (await IngredientService.GetAllAsync())
            .Where(i => !i.IsDeleted)
            .OrderBy(i => i.IngredientName)
            .ToList();
        ApplyFilters();
        isLoading = false;
    }

    private async Task HandleValidSubmit()
    {
        if (isSubmitting) return;
        isSubmitting = true;
        try
        {
            ingredientModel.IngredientName = ingredientModel.IngredientName.ToTitleCase();
            if (ingredientModel.IngredientId == 0)
            {
                ingredientModel.IngredientName = ingredientModel.IngredientName.ToTitleCase();
                await IngredientService.AddAsync(ingredientModel);
            }
            else
                await IngredientService.UpdateAsync(ingredientModel);
            await LoadIngredients();
            ClearForm();
        }
        finally { isSubmitting = false; }
    }

    private void EditIngredient(Ingredient item)
    {
        ingredientModel = new Ingredient { IngredientId = item.IngredientId, IngredientName = item.IngredientName };
        ingredientModel.IngredientName = ingredientModel.IngredientName.ToTitleCase();
        showForm = true;
    }

    private async Task DeleteIngredient(int id)
    {
        if (isSubmitting) return;
        isSubmitting = true;
        try { await IngredientService.DeleteAsync(id); await LoadIngredients(); }
        finally { isSubmitting = false; }
    }

    private void ClearForm() { ingredientModel = new Ingredient(); showForm = false; }
    private void ToggleForm() { showForm = !showForm; if (!showForm) ingredientModel = new Ingredient(); }
    private void ToggleSearch() => showSearch = !showSearch;

    private Task OnFiltersChanged(SearchFilterComponent.SearchFilterCriteria filters)
    {
        currentFilters = filters;
        ApplyFilters();
        return Task.CompletedTask;
    }

    private void ApplyFilters()
    {
        var q = allIngredients.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(currentFilters.SearchTerm))
        {
            var term = currentFilters.SearchTerm.ToLower();
            q = q.Where(i => i.IngredientName.ToLower().Contains(term));
        }
        filteredIngredients = q.ToList();
        StateHasChanged();
    }
}
