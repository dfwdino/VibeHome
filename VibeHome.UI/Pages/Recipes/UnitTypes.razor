@using VibeHome.Application.Interfaces
@using VibeHome.Domain.Entities
@using VibeHome.Domain.Entities.Recipes
@using VibeHome.UI.Shared
@page "/Recipes/unit-types"
@attribute [Authorize(Roles = "recipes")]
@inject IUnitTypeService UnitTypeService

<h3>Unit Types</h3>

<button class="btn btn-primary mb-3" @onclick="ToggleForm">
    @(showForm ? "Hide Form" : "Add Unit Type")
</button>

<div class="collapse @(showForm ? "show" : "")">
    <div class="card card-body mb-3">
        <EditForm Model="unitTypeModel" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <div class="row g-2 mb-3">
                <div class="col-8">
                    <label class="form-label fw-semibold">Unit Name</label>
                    <InputText class="form-control form-control-lg" @bind-Value="unitTypeModel.UnitName"
                               placeholder="e.g. Tablespoon" />
                </div>
                <div class="col-4">
                    <label class="form-label fw-semibold">Abbreviation</label>
                    <InputText class="form-control form-control-lg" @bind-Value="unitTypeModel.Abbreviation"
                               placeholder="e.g. tbsp" />
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success flex-fill" disabled="@isSubmitting">
                    @(unitTypeModel.UnitTypeId == 0 ? "Add Unit Type" : "Update")
                </button>
                @if (unitTypeModel.UnitTypeId != 0)
                {
                    <button type="button" class="btn btn-secondary flex-fill" @onclick="ClearForm" disabled="@isSubmitting">Cancel</button>
                }
            </div>
        </EditForm>
    </div>
</div>

@if (isLoading)
{
    <div class="text-center py-4"><div class="spinner-border text-success" role="status"></div></div>
}
else
{
    <!-- Desktop Table -->
    <div class="d-none d-md-block">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th class="custom-table-header">Unit Name</th>
                    <th class="custom-table-header">Abbreviation</th>
                    <th class="custom-table-header text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in allUnitTypes)
                {
                    <tr>
                        <td>@item.UnitName</td>
                        <td>@item.Abbreviation</td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-info me-1" @onclick="@(() => EditUnitType(item))" disabled="@isSubmitting">Edit</button>
                            <button class="btn btn-sm btn-danger" @onclick="@(async () => await DeleteUnitType(item.UnitTypeId))" disabled="@isSubmitting">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Mobile Cards -->
    <div class="d-block d-md-none">
        @foreach (var item in allUnitTypes)
        {
            <div class="card mb-2 shadow-sm">
                <div class="card-body p-3">
                    <div class="fw-semibold">@item.UnitName <span class="text-muted fs-6">(@item.Abbreviation)</span></div>
                    <div class="mt-2 d-flex gap-2">
                        <button class="btn btn-info flex-fill btn-sm" @onclick="@(() => EditUnitType(item))" disabled="@isSubmitting">Edit</button>
                        <button class="btn btn-danger flex-fill btn-sm" @onclick="@(async () => await DeleteUnitType(item.UnitTypeId))" disabled="@isSubmitting">Delete</button>
                    </div>
                </div>
            </div>
        }
        @if (!allUnitTypes.Any())
        {
            <div class="text-center text-muted py-4">No unit types found.</div>
        }
    </div>
}

@code {
    private List<UnitType> allUnitTypes = new();
    private UnitType unitTypeModel = new();
    private bool showForm = false;
    private bool isLoading = true;
    private bool isSubmitting = false;

    protected override async Task OnInitializedAsync() => await LoadUnitTypes();

    private async Task LoadUnitTypes()
    {
        isLoading = true;
        allUnitTypes = (await UnitTypeService.GetAllAsync())
            .Where(u => !u.IsDeleted)
            .OrderBy(u => u.UnitName)
            .ToList();
        isLoading = false;
    }

    private async Task HandleValidSubmit()
    {
        if (isSubmitting) return;
        isSubmitting = true;
        try
        {
            if (unitTypeModel.UnitTypeId == 0){
                unitTypeModel.UnitName = unitTypeModel.UnitName.ToTitleCase();
          
                await UnitTypeService.AddAsync(unitTypeModel);
            }
            else
                await UnitTypeService.UpdateAsync(unitTypeModel);
            await LoadUnitTypes();
            ClearForm();
        }
        finally { isSubmitting = false; }
    }

    private void EditUnitType(UnitType item)
    {
        unitTypeModel = new UnitType { UnitTypeId = item.UnitTypeId, UnitName = item.UnitName, Abbreviation = item.Abbreviation };
        showForm = true;
    }

    private async Task DeleteUnitType(int id)
    {
        if (isSubmitting) return;
        isSubmitting = true;
        try { await UnitTypeService.DeleteAsync(id); await LoadUnitTypes(); }
        finally { isSubmitting = false; }
    }

    private void ClearForm() { unitTypeModel = new UnitType(); showForm = false; }
    private void ToggleForm() { showForm = !showForm; if (!showForm) unitTypeModel = new UnitType(); }
}
